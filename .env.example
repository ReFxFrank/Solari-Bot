# ─────────────────────────────────────────────────────────────────────────────
# Solari — environment configuration
#
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# All secrets live here only (§5.5, §10).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ── Offsite backups (optional) ──────────────────────────────────────────────
# The backup service always keeps nightly dumps on the VPS (BACKUP_RETENTION_DAYS,
# default 14). Fill these in to ALSO push every dump to an S3-compatible bucket —
# Cloudflare R2, Backblaze B2, AWS S3, MinIO. Setting BACKUP_S3_BUCKET is the
# switch; leave it unset for local-only. Apply with:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile apps up -d backup
# BACKUP_S3_BUCKET=solari-backups
# BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Cloudflare | Backblaze | AWS | Minio | Other (default)
# BACKUP_S3_PROVIDER=Cloudflare
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_PREFIX=solari
# BACKUP_S3_RETENTION_DAYS=30
# BACKUP_S3_REGION=

# ── Error tracking (Sentry, optional) ───────────────────────────────────────
# Create a project at sentry.io (or a self-hosted Sentry) and paste its DSN to
# get bot + dashboard errors reported. Leave unset to disable entirely — the
# SDK never initialises without it. Both apps read this same variable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Database (PostgreSQL 16) ────────────────────────────────────────────────
# Matches the docker-compose Postgres defaults below. For local dev outside
# Docker, point this at your own Postgres instance.
# PRODUCTION: change POSTGRES_PASSWORD to a strong random value (the "helios"
# defaults are for local dev only). In prod the data stores bind to 127.0.0.1
# (docker-compose.prod.yml), so they aren't reachable off-host.
POSTGRES_USER=helios
POSTGRES_PASSWORD=helios
POSTGRES_DB=helios
POSTGRES_PORT=5432
DATABASE_URL=postgresql://helios:helios@localhost:5432/helios?schema=public

# ── Redis 7 (cache / pub-sub / BullMQ) ──────────────────────────────────────
# PRODUCTION: set REDIS_PASSWORD (docker-compose.prod.yml enforces --requirepass)
# and include it in REDIS_URL, e.g. redis://:<REDIS_PASSWORD>@redis:6379
# Generate one with: openssl rand -hex 32
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Discord application ──────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# IMPORTANT: enable the SERVER MEMBERS and MESSAGE CONTENT privileged intents
# in the Bot tab — member events and content-scanning automod require them (§1.6).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Comma-separated Discord user IDs that are bot owners (admin dashboard access).
OWNER_IDS=
# Optional: a guild to register slash commands into for instant dev iteration.
# DEV ONLY — while set, commands exist in that ONE guild and no other server
# can see or autocomplete them. Leave unset in production (global registration;
# first-time propagation can take up to an hour). If you're switching from
# guild-scoped to global, clear the old set once to avoid duplicates there:
#   pnpm deploy:commands -- --clear-guild <that guild id>
DEV_GUILD_ID=

# ── Lavalink v4 (Music module — premium) ─────────────────────────────────────
# Music is a premium module. Set MUSIC_ENABLED=true AND run a Lavalink node
# (docker compose --profile music up -d lavalink) for the bot to connect. Then
# enable the Music module for a Premium server in the dashboard and run
# `pnpm deploy:commands` to register /play, /skip, /queue, etc.
# Leave MUSIC_ENABLED unset to keep the bot from dialing a Lavalink node at all.
MUSIC_ENABLED=false
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ── Encryption (Phase 4) ─────────────────────────────────────────────────────
# 32+ byte secret used to encrypt operator-supplied third-party API tokens at
# rest (e.g. social integrations). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Dashboard auth (Auth.js / NextAuth v5 — Phase 2) ─────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the dashboard (used by Auth.js callbacks). In production this is
# your HTTPS domain, e.g. https://dash.example.com (see the Production section
# below and SETUP.md §11).
AUTH_URL=http://localhost:3000
WEB_PORT=3000
# IMPORTANT: in the Discord Developer Portal → OAuth2, add this Redirect URL:
#   ${AUTH_URL}/api/auth/callback/discord   (e.g. http://localhost:3000/api/auth/callback/discord)
# The dashboard reuses DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET above with the
# `identify guilds` scopes.

# ── Production edge (domain + HTTPS via Cloudflare + Caddy) — optional ───────
# Only used by docker-compose.prod.yml. Cloudflare fronts the domain (proxied /
# orange cloud) and terminates public TLS; Caddy serves a Cloudflare Origin
# Certificate on the origin (SSL/TLS mode "Full (strict)"). Full walkthrough in
# SETUP.md §11. After setting the domain:
#   1. Set AUTH_URL above to https://<SOLARI_DOMAIN>
#   2. Add https://<SOLARI_DOMAIN>/api/auth/callback/discord as a Discord redirect
#   3. Point the live Stripe webhook at https://<SOLARI_DOMAIN>/api/stripe/webhook
#   4. Drop the Cloudflare origin cert into infra/caddy/certs/ (origin.pem + origin.key)
# SOLARI_DOMAIN=solari.gg

# ── Optional integration API keys (Phase 4 — Social notifications) ───────────
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# YOUTUBE_API_KEY=

# ── top.gg voting (optional) ─────────────────────────────────────────────────
# If the bot is listed on top.gg: register the webhook
# https://<SOLARI_DOMAIN>/api/integrations/topgg in the top.gg webhooks panel
# with this same Authorization value (the receiver rejects everything until it
# is set). Members then claim economy rewards with /vote. Generate with:
# openssl rand -hex 32
# TOPGG_WEBHOOK_AUTH=
# Only needed if the top.gg listing id differs from DISCORD_CLIENT_ID:
# TOPGG_BOT_ID=

# ── Premium billing (Stripe, per-server) — optional ──
# Leave blank to disable the upgrade flow (dashboard shows "billing not configured").
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
