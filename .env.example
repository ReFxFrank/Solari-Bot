# ─────────────────────────────────────────────────────────────────────────────
# Helios — environment configuration
#
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# All secrets live here only (§5.5, §10).
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# development | test | production
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ── Database (PostgreSQL 16) ────────────────────────────────────────────────
# Matches the docker-compose Postgres defaults below. For local dev outside
# Docker, point this at your own Postgres instance.
POSTGRES_USER=helios
POSTGRES_PASSWORD=helios
POSTGRES_DB=helios
POSTGRES_PORT=5432
DATABASE_URL=postgresql://helios:helios@localhost:5432/helios?schema=public

# ── Redis 7 (cache / pub-sub / BullMQ) ──────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Discord application ──────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# IMPORTANT: enable the SERVER MEMBERS and MESSAGE CONTENT privileged intents
# in the Bot tab — member events and content-scanning automod require them (§1.6).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Comma-separated Discord user IDs that are bot owners (admin dashboard access).
OWNER_IDS=
# Optional: a guild to register slash commands into for instant dev iteration.
DEV_GUILD_ID=

# ── Lavalink v4 (music — Phase 4, optional `music` compose profile) ──────────
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ── Encryption (Phase 4) ─────────────────────────────────────────────────────
# 32+ byte secret used to encrypt operator-supplied third-party API tokens at
# rest (e.g. social integrations). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Dashboard auth (Auth.js / NextAuth v5 — Phase 2) ─────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the dashboard (used by Auth.js callbacks).
AUTH_URL=http://localhost:3000
WEB_PORT=3000
# IMPORTANT: in the Discord Developer Portal → OAuth2, add this Redirect URL:
#   ${AUTH_URL}/api/auth/callback/discord   (e.g. http://localhost:3000/api/auth/callback/discord)
# The dashboard reuses DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET above with the
# `identify guilds` scopes.

# ── ReFx Hosting status integration ──────────────────────────────────────────
# The bot's /refxstatus command and the dashboard /status page read this public
# endpoint. Override only if self-hosting the ReFx panel under a different host.
# REFX_STATUS_URL=https://api.refx.gg/api/v1/status
#
# Optional: a status:read bearer token unlocks the authenticated node-metrics
# feed (per-node CPU/RAM/disk/players). Without it, both surfaces show only the
# public feed above. REFX_NODES_URL overrides the authenticated endpoint.
# REFX_STATUS_TOKEN=
# REFX_NODES_URL=https://api.refx.gg/api/v1/status/nodes
#
# Optional: enable real-time incident alerts. The dashboard exposes a webhook
# receiver at ${AUTH_URL}/api/integrations/refx; register it + this shared secret
# in the ReFx panel. The receiver verifies every request's HMAC signature and
# returns 503 until this is set (it never accepts unsigned traffic). Must match
# the value configured in the ReFx backend. Generate with: openssl rand -hex 32
# REFX_WEBHOOK_SECRET=

# ── Optional integration API keys (Phase 4 — Social notifications) ───────────
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# YOUTUBE_API_KEY=
