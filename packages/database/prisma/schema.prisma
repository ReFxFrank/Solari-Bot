// Solari — Prisma schema (single source of truth for the data model).
//
// Phase 0 ships the foundational models needed for the config-sync spine:
// Guild metadata, per-(guild, module) configuration, and the dashboard audit
// log. Feature tables (ModerationCase, UserLevel, Giveaway, ...) are added in
// their respective phases per the build brief §6.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Every configurable feature area. Mirrors the `Module` union in
/// `@solari/shared` — keep the two in sync.
enum Module {
  MODERATION
  AUTOMOD
  LOGGING
  WELCOME
  AUTOROLE
  LEVELING
  ROLES
  CUSTOM_COMMANDS
  STARBOARD
  GIVEAWAYS
  POLLS
  SUGGESTIONS
  REMINDERS
  SCHEDULED_MESSAGES
  TICKETS
  STATS_COUNTERS
  INVITE_TRACKING
  BIRTHDAYS
  AFK
  ECONOMY
  MUSIC
  SOCIAL
  TEMP_VOICE
  REFX_ALERTS
  UTILITY
  FUN
}

enum PremiumTier {
  FREE
  PREMIUM
}

enum BlacklistType {
  GUILD
  USER
}

/// Bot-owner blacklist (§ admin): a guild or user barred from using the bot.
/// The bot loads these into memory and refuses commands from a match.
model Blacklist {
  id        String        @id @default(cuid())
  type      BlacklistType
  /// Guild or user snowflake, depending on `type`.
  targetId  String
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([type, targetId])
  @@index([type])
}

/// Guild metadata mirror (§4.4). The bot upserts these rows from gateway
/// events so the dashboard never needs to hit the Discord API for basics.
model Guild {
  id           String      @id // Discord snowflake
  name         String?
  icon         String? // icon hash
  ownerId      String?
  memberCount  Int         @default(0)
  joinedAt     DateTime    @default(now())
  premiumTier  PremiumTier @default(FREE)
  featureFlags Json        @default("{}")
  locale       String      @default("en-US")
  timezone     String      @default("UTC")
  prefix       String      @default("!")
  /// Monotonic per-guild counter used to allocate ModerationCase numbers
  /// atomically (incremented in a single UPDATE — collision-safe under
  /// concurrency, unlike a global serial).
  caseCounter  Int         @default(0)
  /// Same atomic-increment scheme for per-guild ticket numbers.
  ticketCounter Int        @default(0)
  /// Same atomic-increment scheme for per-guild suggestion numbers.
  suggestionCounter Int    @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  moduleConfigs GuildModuleConfig[]
  auditLogs     DashboardAuditLog[]
  cases         ModerationCase[]
  userLevels    UserLevel[]
  rolePanels    ReactionRolePanel[]
  starboard     StarboardMessage[]
  giveaways     Giveaway[]
  reminders         Reminder[]
  scheduledMessages ScheduledMessage[]
  tickets           Ticket[]
  customCommands    CustomCommand[]
  suggestions       Suggestion[]
  polls             Poll[]
  afkUsers          Afk[]
  birthdays         Birthday[]
  inviteUses        InviteUse[]
  subscription      GuildSubscription?
  tempVoiceChannels TempVoiceChannel[]
  economyUsers      EconomyUser[]
  socialSubscriptions SocialSubscription[]

  @@index([ownerId])
}

/// A Social Alerts subscription (premium): watch a Twitch/YouTube/Reddit/RSS
/// source and post new items to a channel. `lastItemId` dedups what's been
/// posted; a per-subscription BullMQ job polls on an interval.
model SocialSubscription {
  id            String   @id @default(cuid())
  guildId       String
  /// twitch | youtube | reddit | rss
  platform      String
  /// Twitch login / YouTube channel id / subreddit / feed URL.
  target        String
  /// Discord channel the alerts post to.
  channelId     String
  /// Optional role to ping on a new item.
  mentionRoleId String?
  /// Id of the most recent item already posted (dedup).
  lastItemId    String?
  createdAt     DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

/// Per-(guild, user) economy balance (premium). `wallet` is spendable/robbable;
/// `bank` is safe. Cooldowns for /daily and /work are timestamp-based (no jobs).
model EconomyUser {
  id        String    @id @default(cuid())
  guildId   String
  userId    String
  wallet    Int       @default(0)
  bank      Int       @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([guildId, wallet])
}

/// A "join-to-create" temporary voice channel spawned by the Temp Voice module
/// (premium). Rows let the bot clean up orphaned channels on restart and resolve
/// a channel's owner for the /voice control commands.
model TempVoiceChannel {
  channelId String   @id // the created voice channel's snowflake
  guildId   String
  ownerId   String // the member who spawned it
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

/// Per-server premium subscription (§3). One row per guild. The bot reads the
/// fast `Guild.premiumTier` flag; this table holds the Stripe billing details
/// and the authoritative `status`, kept in sync by the Stripe webhook. Billing
/// is per-server (a subscription upgrades a single guild).
model GuildSubscription {
  guildId              String    @id
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  /// Mirrors the Stripe subscription status: active, trialing, past_due,
  /// canceled, incomplete, etc. `inactive` = never subscribed.
  status               String    @default("inactive")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

/// One row per (guild, module). `config` is a JSON blob validated by the
/// matching zod schema in `@solari/shared` on every read and write (§4.1).
model GuildModuleConfig {
  id        String   @id @default(cuid())
  guildId   String
  module    Module
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  updatedBy String? // Discord user id of the last editor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, module])
  @@index([guildId])
}

/// Records every dashboard configuration change (actor, module, before/after).
model DashboardAuditLog {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  action    String
  module    Module?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, createdAt])
}

enum CaseType {
  WARN
  MUTE
  KICK
  BAN
  SOFTBAN
  TEMPBAN
  UNBAN
  NOTE
}

enum RolePanelMode {
  NORMAL // toggle each role on/off
  UNIQUE // one role from the panel at a time
  VERIFY // grant only; clicking never removes
}

enum RolePanelType {
  BUTTON
  SELECT
}

/// A self-assignable role panel (§8E). Options ([{roleId,label,emoji?}]) are
/// stored as JSON; `messageId` is set once the panel is deployed to a channel.
model ReactionRolePanel {
  id          String        @id @default(cuid())
  guildId     String
  channelId   String?
  messageId   String?
  title       String
  description String?
  mode        RolePanelMode @default(NORMAL)
  type        RolePanelType @default(BUTTON)
  options     Json          @default("[]")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([messageId])
}

/// A giveaway (§8G). `requirements` is a JSON blob ({ roleIds: [] }); winners
/// are drawn from GiveawayEntry rows by the durable `giveawayEnd` job.
model Giveaway {
  id           String   @id @default(cuid())
  guildId      String
  channelId    String
  messageId    String?
  prize        String
  winnerCount  Int      @default(1)
  requirements Json     @default("{}")
  endsAt       DateTime
  ended        Boolean  @default(false)
  createdBy    String
  createdAt    DateTime @default(now())

  guild   Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  entries GiveawayEntry[]

  @@index([guildId])
  @@index([ended, endsAt])
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  userId     String
  createdAt  DateTime @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, userId])
  @@index([giveawayId])
}

/// Maps a starred source message to its posted starboard message (§8G), so the
/// board entry can be updated/removed as the star count changes.
model StarboardMessage {
  id                String   @id @default(cuid())
  guildId           String
  sourceChannelId   String
  sourceMessageId   String
  starboardMessageId String?
  count             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, sourceMessageId])
  @@index([guildId])
}

/// Per-guild, per-user XP/level state (§8D). Level rewards are stored in the
/// leveling module config, not here.
model UserLevel {
  id           String    @id @default(cuid())
  guildId      String
  userId       String
  xp           Int       @default(0)
  level        Int       @default(0)
  messages     Int       @default(0)
  voiceMinutes Int       @default(0)
  lastXpAt     DateTime?
  updatedAt    DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([guildId, xp])
}

/// A numbered moderation action (§6). `caseNumber` is per-guild (see
/// Guild.caseCounter). Temp actions carry `duration`/`expiresAt` and are
/// reversed by the durable `tempActionExpire` job, never a timer.
model ModerationCase {
  id          String    @id @default(cuid())
  guildId     String
  caseNumber  Int
  type        CaseType
  targetId    String // Discord user id the action was taken against
  moderatorId String // Discord user id of the acting moderator
  reason      String?
  duration    Int? // seconds, for temp actions
  expiresAt   DateTime?
  active      Boolean   @default(true) // false once a temp action has expired/been reversed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId])
  @@index([guildId, targetId])
  @@index([active, expiresAt])
}

/// How often a scheduled message repeats. Mirrors `ScheduleRepeat` in
/// `@solari/shared` — keep the two in sync.
enum ScheduleRepeat {
  NONE
  HOURLY
  DAILY
  WEEKLY
}

/// A personal/server reminder (§8 Reminders). Fired by the durable `reminder`
/// job — never a timer — and removed once delivered. Scoped to the guild it was
/// created in so the owning shard can re-arm it on startup.
model Reminder {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  userId    String
  content   String
  remindAt  DateTime
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([userId])
  @@index([remindAt])
}

/// A scheduled / recurring announcement (§8 Scheduled messages). The durable
/// `scheduledMessage` job posts `content` to `channelId` at `nextRunAt`; if
/// `repeat` is not NONE it re-arms itself for the next interval, otherwise it
/// flips `enabled` off after firing once.
model ScheduledMessage {
  id        String         @id @default(cuid())
  guildId   String
  channelId String
  name      String?
  content   String
  repeat    ScheduleRepeat @default(NONE)
  nextRunAt DateTime
  lastRunAt DateTime?
  enabled   Boolean        @default(true)
  createdBy String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([enabled, nextRunAt])
}

enum TicketStatus {
  OPEN
  CLOSED
}

/// A support ticket (§8 Tickets). Backed by a private channel; closed by a
/// user/command or the durable `ticketAutoClose` job after inactivity. The
/// channel is deleted on close after a transcript is archived.
model Ticket {
  id             String       @id @default(cuid())
  guildId        String
  channelId      String       @unique
  number         Int
  openerId       String
  status         TicketStatus @default(OPEN)
  closedById     String?
  closedAt       DateTime?
  lastActivityAt DateTime     @default(now())
  createdAt      DateTime     @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, number])
  @@index([guildId, status])
}

/// A custom command / tag (§8). Invoked by `{prefix}{name}` or `/tag show`.
/// `content` is optional text and `embed` an optional EmbedSpec JSON — at least
/// one is present (enforced at the dashboard/command boundary).
model CustomCommand {
  id        String   @id @default(cuid())
  guildId   String
  name      String // stored lowercased
  content   String?
  embed     Json?
  uses      Int      @default(0)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, name])
  @@index([guildId])
}

enum SuggestionStatus {
  PENDING
  APPROVED
  DENIED
  IMPLEMENTED
}

/// A community suggestion (§8). Posted to the configured channel with up/down
/// vote buttons; staff move it through statuses. `number` is per-guild.
model Suggestion {
  id          String           @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?
  number      Int
  authorId    String
  content     String
  status      SuggestionStatus @default(PENDING)
  staffId     String?
  staffReason String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  guild Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  votes SuggestionVote[]

  @@unique([guildId, number])
  @@index([guildId])
}

model SuggestionVote {
  id           String @id @default(cuid())
  suggestionId String
  userId       String
  value        Int // +1 or -1

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

/// A single-choice poll (§8). `options` is a JSON string[]; one vote per user
/// (re-voting replaces). Closed by `/poll end` or the durable `pollEnd` job.
model Poll {
  id        String    @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  question  String
  options   Json
  endsAt    DateTime?
  ended     Boolean   @default(false)
  createdBy String
  createdAt DateTime  @default(now())

  guild Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([guildId])
  @@index([ended, endsAt])
}

model PollVote {
  id          String @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
}

/// A user's AFK status in a guild (§8). Set with /afk, cleared on their next
/// message; mentions of an AFK user trigger a notice.
model Afk {
  id      String   @id @default(cuid())
  guildId String
  userId  String
  reason  String?
  since   DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
}

/// A user's birthday in a guild (§8). The durable `birthdayAnnounce` job greets
/// today's birthdays and rotates the optional birthday role. `year` is optional
/// (age display); month/day drive the announcement.
model Birthday {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  month     Int // 1–12
  day       Int // 1–31
  year      Int?
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId, month, day])
}

/// One row per tracked join (§8 Invite tracking). `inviterId` is null for a
/// vanity-URL or undeterminable join. Leaderboards aggregate by inviterId.
model InviteUse {
  id            String   @id @default(cuid())
  guildId       String
  inviterId     String?
  invitedUserId String
  code          String?
  createdAt     DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, invitedUserId])
  @@index([guildId, inviterId])
  @@index([guildId])
}
