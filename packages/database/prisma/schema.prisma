// Helios — Prisma schema (single source of truth for the data model).
//
// Phase 0 ships the foundational models needed for the config-sync spine:
// Guild metadata, per-(guild, module) configuration, and the dashboard audit
// log. Feature tables (ModerationCase, UserLevel, Giveaway, ...) are added in
// their respective phases per the build brief §6.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Every configurable feature area. Mirrors the `Module` union in
/// `@helios/shared` — keep the two in sync.
enum Module {
  MODERATION
  AUTOMOD
  LOGGING
  WELCOME
  AUTOROLE
  LEVELING
  ROLES
  CUSTOM_COMMANDS
  STARBOARD
  GIVEAWAYS
  POLLS
  SUGGESTIONS
  REMINDERS
  SCHEDULED_MESSAGES
  TICKETS
  STATS_COUNTERS
  INVITE_TRACKING
  BIRTHDAYS
  AFK
  ECONOMY
  MUSIC
  SOCIAL
  TEMP_VOICE
  UTILITY
  FUN
}

enum PremiumTier {
  FREE
  PREMIUM
}

/// Guild metadata mirror (§4.4). The bot upserts these rows from gateway
/// events so the dashboard never needs to hit the Discord API for basics.
model Guild {
  id           String      @id // Discord snowflake
  name         String?
  icon         String? // icon hash
  ownerId      String?
  memberCount  Int         @default(0)
  joinedAt     DateTime    @default(now())
  premiumTier  PremiumTier @default(FREE)
  featureFlags Json        @default("{}")
  locale       String      @default("en-US")
  timezone     String      @default("UTC")
  prefix       String      @default("!")
  /// Monotonic per-guild counter used to allocate ModerationCase numbers
  /// atomically (incremented in a single UPDATE — collision-safe under
  /// concurrency, unlike a global serial).
  caseCounter  Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  moduleConfigs GuildModuleConfig[]
  auditLogs     DashboardAuditLog[]
  cases         ModerationCase[]
  userLevels    UserLevel[]
  rolePanels    ReactionRolePanel[]
  starboard     StarboardMessage[]
  giveaways     Giveaway[]
  reminders         Reminder[]
  scheduledMessages ScheduledMessage[]

  @@index([ownerId])
}

/// One row per (guild, module). `config` is a JSON blob validated by the
/// matching zod schema in `@helios/shared` on every read and write (§4.1).
model GuildModuleConfig {
  id        String   @id @default(cuid())
  guildId   String
  module    Module
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  updatedBy String? // Discord user id of the last editor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, module])
  @@index([guildId])
}

/// Records every dashboard configuration change (actor, module, before/after).
model DashboardAuditLog {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  action    String
  module    Module?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([guildId, createdAt])
}

enum CaseType {
  WARN
  MUTE
  KICK
  BAN
  SOFTBAN
  TEMPBAN
  UNBAN
  NOTE
}

enum RolePanelMode {
  NORMAL // toggle each role on/off
  UNIQUE // one role from the panel at a time
  VERIFY // grant only; clicking never removes
}

enum RolePanelType {
  BUTTON
  SELECT
}

/// A self-assignable role panel (§8E). Options ([{roleId,label,emoji?}]) are
/// stored as JSON; `messageId` is set once the panel is deployed to a channel.
model ReactionRolePanel {
  id          String        @id @default(cuid())
  guildId     String
  channelId   String?
  messageId   String?
  title       String
  description String?
  mode        RolePanelMode @default(NORMAL)
  type        RolePanelType @default(BUTTON)
  options     Json          @default("[]")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([messageId])
}

/// A giveaway (§8G). `requirements` is a JSON blob ({ roleIds: [] }); winners
/// are drawn from GiveawayEntry rows by the durable `giveawayEnd` job.
model Giveaway {
  id           String   @id @default(cuid())
  guildId      String
  channelId    String
  messageId    String?
  prize        String
  winnerCount  Int      @default(1)
  requirements Json     @default("{}")
  endsAt       DateTime
  ended        Boolean  @default(false)
  createdBy    String
  createdAt    DateTime @default(now())

  guild   Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  entries GiveawayEntry[]

  @@index([guildId])
  @@index([ended, endsAt])
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  userId     String
  createdAt  DateTime @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, userId])
  @@index([giveawayId])
}

/// Maps a starred source message to its posted starboard message (§8G), so the
/// board entry can be updated/removed as the star count changes.
model StarboardMessage {
  id                String   @id @default(cuid())
  guildId           String
  sourceChannelId   String
  sourceMessageId   String
  starboardMessageId String?
  count             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, sourceMessageId])
  @@index([guildId])
}

/// Per-guild, per-user XP/level state (§8D). Level rewards are stored in the
/// leveling module config, not here.
model UserLevel {
  id           String    @id @default(cuid())
  guildId      String
  userId       String
  xp           Int       @default(0)
  level        Int       @default(0)
  messages     Int       @default(0)
  voiceMinutes Int       @default(0)
  lastXpAt     DateTime?
  updatedAt    DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([guildId, xp])
}

/// A numbered moderation action (§6). `caseNumber` is per-guild (see
/// Guild.caseCounter). Temp actions carry `duration`/`expiresAt` and are
/// reversed by the durable `tempActionExpire` job, never a timer.
model ModerationCase {
  id          String    @id @default(cuid())
  guildId     String
  caseNumber  Int
  type        CaseType
  targetId    String // Discord user id the action was taken against
  moderatorId String // Discord user id of the acting moderator
  reason      String?
  duration    Int? // seconds, for temp actions
  expiresAt   DateTime?
  active      Boolean   @default(true) // false once a temp action has expired/been reversed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, caseNumber])
  @@index([guildId])
  @@index([guildId, targetId])
  @@index([active, expiresAt])
}

/// How often a scheduled message repeats. Mirrors `ScheduleRepeat` in
/// `@helios/shared` — keep the two in sync.
enum ScheduleRepeat {
  NONE
  HOURLY
  DAILY
  WEEKLY
}

/// A personal/server reminder (§8 Reminders). Fired by the durable `reminder`
/// job — never a timer — and removed once delivered. Scoped to the guild it was
/// created in so the owning shard can re-arm it on startup.
model Reminder {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  userId    String
  content   String
  remindAt  DateTime
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([userId])
  @@index([remindAt])
}

/// A scheduled / recurring announcement (§8 Scheduled messages). The durable
/// `scheduledMessage` job posts `content` to `channelId` at `nextRunAt`; if
/// `repeat` is not NONE it re-arms itself for the next interval, otherwise it
/// flips `enabled` off after firing once.
model ScheduledMessage {
  id        String         @id @default(cuid())
  guildId   String
  channelId String
  name      String?
  content   String
  repeat    ScheduleRepeat @default(NONE)
  nextRunAt DateTime
  lastRunAt DateTime?
  enabled   Boolean        @default(true)
  createdBy String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([enabled, nextRunAt])
}
