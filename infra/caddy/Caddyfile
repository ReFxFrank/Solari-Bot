# Solari — production edge behind Cloudflare (proxied / orange cloud).
#
# Cloudflare terminates public TLS for solari.gg at its edge and connects back to
# this origin over HTTPS. Caddy serves a Cloudflare *Origin Certificate* (trusted
# only by Cloudflare, valid for years) so you can safely run SSL/TLS mode
# "Full (strict)". There is no Let's Encrypt / ACME here on purpose — Cloudflare's
# proxy would intercept the ACME challenge and it would never complete.
#
# Create the origin cert in the Cloudflare dashboard:
#   SSL/TLS → Origin Server → Create Certificate  (accept the defaults)
# Save the two blocks onto the VPS as:
#   infra/caddy/certs/origin.pem   (the certificate)
#   infra/caddy/certs/origin.key   (the private key — never commit it)
#
# SOLARI_DOMAIN comes from the caddy service environment in docker-compose.prod.yml.
# Providing an explicit `tls` cert below tells Caddy NOT to attempt ACME for this
# site, so nothing here ever reaches out to Let's Encrypt.

{$SOLARI_DOMAIN} {
	encode zstd gzip

	# Serve the Cloudflare origin certificate on the internal HTTPS leg.
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

	# Forward everything to the Next.js dashboard. `web` is the compose service
	# name; 3000 is its in-container port.
	reverse_proxy web:3000

	# Sensible security headers for a dashboard behind TLS.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
